{
  "folders": [
    {
      "path": "."
    }
  ],
  "extensions": {
    "recommendations": [
      "ms-python.python",
      "ms-python.vscode-pylance",
      "charliermarsh.ruff"
    ]
  },
  "settings": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "charliermarsh.ruff",
    "[python]": {
      "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "ruff.fixAll": true,
    "ruff.organizeImports": true,
    "python.analysis.typeCheckingMode": "basic"
  }
}